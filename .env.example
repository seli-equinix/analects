# CCA Environment Configuration
# Copy to .env and edit with your values.
#
# These env vars OVERRIDE config.toml values when set.
# Leave commented to use config.toml defaults.

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

OPENAI_API_KEY=dummy
# OPENAI_BASE_URL=http://localhost:8000/v1

# Workspace mount (host path mapped into the container)
CCA_WORKSPACE=/path/to/your/code

# Redis (with authentication)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ──────────────────────────────────────────────
# GITLAB / CI (for scripts/ci.py, dashboard, workspace-sync)
# ──────────────────────────────────────────────

GITLAB_TOKEN=glpat-YOUR_TOKEN_HERE
GITLAB_PASS=YOUR_GITLAB_PASSWORD
# GITLAB_URL=http://localhost:8929
# GITLAB_USER=root
# GITLAB_PROJECT_ID=4

# Docker registry credentials (for CI build jobs)
REGISTRY_PASS=YOUR_REGISTRY_PASSWORD
# REGISTRY_USER=admin

# ──────────────────────────────────────────────
# SERVICE URL OVERRIDES (optional)
# ──────────────────────────────────────────────
# Uncomment to override config.toml [services] values.
# When left empty or commented, Python reads from config.toml.

# REDIS_URL=redis://:password@localhost:6379/0
# QDRANT_URL=http://localhost:6333
# EMBEDDING_URL=http://localhost:8200
# SEARXNG_URL=http://localhost:8888
# MEMGRAPH_HOST=localhost
# MEMGRAPH_PORT=7687

# ──────────────────────────────────────────────
# OBSERVABILITY (optional)
# ──────────────────────────────────────────────

# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
# PHOENIX_PROJECT_NAME=cca

# ──────────────────────────────────────────────
# INFRA EXPERT SSH CREDENTIALS (optional)
# ──────────────────────────────────────────────
# SSH credentials for the Infrastructure expert to access remote nodes.
# Only needed if you use the INFRA route with remote SSH commands.
#
# Global default (applies to all nodes unless overridden in infrastructure.toml):
# CCA_SSH_PASSWORD=your-ssh-password
#
# Per-node overrides (set ssh_password_env on nodes in infrastructure.toml):
# SSH_PASS_SPARK1=password-for-spark1
# SSH_PASS_SPARK2=password-for-spark2
