# CCA Environment Configuration
# Copy to .env and edit with real values

# LLM Backend
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://YOUR_VLLM_HOST:8000/v1

# Workspace mount (host path for file operations)
CCA_WORKSPACE=/home/user/code

# Redis (user awareness, trajectories)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379/0
