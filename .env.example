# ═══════════════════════════════════════════════════
# Analects Full Stack — Environment Configuration
# ═══════════════════════════════════════════════════
# cp .env.example .env   — then fill in your values
#
# These env vars configure ALL services in the stack.
# Analects also reads config.toml for LLM providers and service URLs.
# Env vars here OVERRIDE config.toml values when set.

# ── REQUIRED: Secrets (no defaults — stack will not start without these) ──
REDIS_PASSWORD=
SEARXNG_SECRET_KEY=
OPENAI_API_KEY=dummy

# ── REQUIRED: Redis URL for Analects (must include your REDIS_PASSWORD) ──
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ── REQUIRED: Main vLLM URL (running on a separate machine) ──
VLLM_URL=http://YOUR_VLLM_HOST:8000

# ── REQUIRED: Model weights directory on host ──
MODELS_DIR=/data/models

# ── REQUIRED: Workspace (host path mounted into Analects container) ──
CCA_WORKSPACE=/path/to/your/code

# ── OPTIONAL: Git server credentials (for workspace-sync) ──
# Workspace-sync clones repos defined in config.toml [workspace] section.
# Set the password/token here — config.toml references them via ${VAR}.
# GITLAB_PASS=your-gitlab-password
# GITHUB_TOKEN=ghp_your_token_here

# ── OPTIONAL: Docker images (defaults pull from Docker Hub) ──
# CCA_IMAGE=hellohal2064/analects:latest
# EMBEDDING_IMAGE=hellohal2064/cca-embedding-server:latest
# NOTETAKER_IMAGE=hellohal2064/cca-notetaker:latest
# FUNCTIONARY_IMAGE=hellohal2064/cca-functionary-router:latest

# ── OPTIONAL: Data directories (defaults = /data/*) ──
# REDIS_DATA=/data/memory-tier/redis
# REDIS_MAXMEMORY=10gb
# QDRANT_STORAGE=/data/qdrant/storage
# QDRANT_SNAPSHOTS=/data/qdrant/snapshots
# MEMGRAPH_DATA=/data/memgraph/data
# MEMGRAPH_LOG=/data/memgraph/log

# ── OPTIONAL: Port overrides ──
# REDIS_PORT=6379
# QDRANT_REST_PORT=6333
# QDRANT_GRPC_PORT=6334
# MEMGRAPH_PORT=7687
# MEMGRAPH_LAB_PORT=3100
# SEARXNG_PORT=8888
# EMBEDDING_PORT=8200
# NOTETAKER_PORT=8400
# FUNCTIONARY_PORT=8001

# ── OPTIONAL: Note-taker model override ──
# NOTETAKER_MODEL=/models/Qwen3.5-9B-FP8
# NOTETAKER_MAX_LEN=32768
# NOTETAKER_GPU_MEM=0.5

# ── OPTIONAL: Service URL overrides ──
# Uncomment to override config.toml [services] values.
# QDRANT_URL=http://localhost:6333
# EMBEDDING_URL=http://localhost:8200
# SEARXNG_URL=http://localhost:8888
# MEMGRAPH_HOST=localhost
# MEMGRAPH_PORT=7687

# ── OPTIONAL: Observability (Phoenix / OpenTelemetry) ──
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
# PHOENIX_PROJECT_NAME=analects

# ── OPTIONAL: GitLab CI (for scripts/ci.py, dashboard) ──
# GITLAB_TOKEN=glpat-YOUR_TOKEN_HERE
# GITLAB_PROJECT_ID=4
# REGISTRY_PASS=YOUR_REGISTRY_PASSWORD

# ── OPTIONAL: Infra expert SSH credentials ──
# CCA_SSH_PASSWORD=your-ssh-password
# SSH_PASS_SPARK1=password-for-spark1
# SSH_PASS_SPARK2=password-for-spark2
