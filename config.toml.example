# CCA (Confucius Code Agent) Configuration
# Copy to config.toml and edit for your infrastructure.
#
# Switch between "cloud" and "local" provider sets per role.
# Edit [active] section to toggle — no code changes needed.
#
# Required environment variables (set in .env or shell):
#   REDIS_URL       — Full Redis URL with auth, e.g. redis://:password@host:6379/0
#   GITLAB_TOKEN    — GitLab Personal Access Token (for CI scripts/dashboard)
#   OPENAI_API_KEY  — Set to "dummy" for local vLLM (it doesn't validate keys)
#
# Optional environment variables:
#   GITLAB_URL          — GitLab base URL (default: http://localhost:8929)
#   GITLAB_PASS         — GitLab password (for workspace-sync)
#   GITLAB_PROJECT_ID   — GitLab project ID (default: 4)
#   PHOENIX_URL         — Phoenix UI URL (default: http://localhost:6006)

# Models matching these prefixes route through OpenAILLMManager
# (top-level key — must be before any [section] headers)
openai_model_prefixes = ["qwen", "/models/"]

[active]
coder = "local"             # "cloud" = Azure GPT-5.2, "local" = local vLLM
note_taker = "local"        # "cloud" = Bedrock Claude Sonnet, "local" = local vLLM
tool_orchestrator = "local" # 8B model for research tool iterations
planner = "local"           # optional — comment out to use hardcoded default
reviewer = "local"          # optional — comment out to disable code review expert
tester = "local"            # optional — comment out to disable test generator expert
search = "local"            # primary for SEARCH route
search_researcher = "local" # researcher for SEARCH tool iterations

# ──────────────────────────────────────────────
# CLOUD PROVIDERS (example — edit for your cloud accounts)
# ──────────────────────────────────────────────

[providers.cloud.planner]
model = "gpt-4o"
provider = "azure"
initial_max_tokens = 4096
temperature = 0.2
thinking_budget = 16384

[providers.cloud.reviewer]
model = "gpt-4o"
provider = "azure"
initial_max_tokens = 4096
temperature = 0.1
thinking_budget = 8192

[providers.cloud.tester]
model = "gpt-4o"
provider = "azure"
initial_max_tokens = 4096
temperature = 0.3
thinking_budget = 8192

[providers.cloud.coder]
model = "gpt-4o"
provider = "azure"
initial_max_tokens = 8192
temperature = 0.3
thinking_budget = 32768
cost_per_1m_input = 2.00
cost_per_1m_output = 8.00

[providers.cloud.note_taker]
model = "claude-sonnet-4-5"
provider = "bedrock"
initial_max_tokens = 16384
temperature = 0.3
top_p = 0.7
thinking_budget = 8192
cost_per_1m_input = 3.00
cost_per_1m_output = 15.00

# ──────────────────────────────────────────────
# LOCAL PROVIDERS (edit base_url for your vLLM endpoints)
# ──────────────────────────────────────────────

[providers.local.coder]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 8192
max_tokens = 16384
temperature = 0.3
cost_per_1m_input = 0.0
cost_per_1m_output = 0.0

[providers.local.note_taker]
model = "/models/YOUR_SMALL_MODEL"
provider = "openai"
base_url = "http://localhost:8400/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 4096
max_tokens = 8192
temperature = 0.3
top_p = 0.9
cost_per_1m_input = 0.0
cost_per_1m_output = 0.0

[providers.local.planner]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 4096
max_tokens = 8192
temperature = 0.2

[providers.local.reviewer]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 4096
max_tokens = 8192
temperature = 0.1

[providers.local.tool_orchestrator]
model = "/models/YOUR_SMALL_MODEL"
provider = "openai"
base_url = "http://localhost:8400/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 2048
max_tokens = 2048
temperature = 0.3

[providers.local.tester]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 4096
max_tokens = 8192
temperature = 0.3

[providers.local.search]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 32768
max_tokens = 32768
temperature = 0.2
cost_per_1m_input = 0.0
cost_per_1m_output = 0.0

[providers.local.search_researcher]
model = "/models/YOUR_MODEL_NAME"
provider = "openai"
base_url = "http://YOUR_VLLM_HOST:8000/v1"
api_key_env = "OPENAI_API_KEY"
initial_max_tokens = 4096
max_tokens = 8192
temperature = 0.3
cost_per_1m_input = 0.0
cost_per_1m_output = 0.0

# ──────────────────────────────────────────────
# INFRASTRUCTURE SERVICES
# ──────────────────────────────────────────────
# All backend service endpoints. Python code reads from here;
# env vars (REDIS_URL, QDRANT_URL, etc.) override when set.

[services]
redis_url = "redis://:YOUR_REDIS_PASSWORD@localhost:6379/0"
qdrant_url = "http://localhost:6333"
embedding_url = "http://localhost:8200"
searxng_url = "http://localhost:8888"
memgraph_host = "localhost"
memgraph_port = 7687
phoenix_endpoint = ""                  # empty = tracing disabled
phoenix_project = "cca"
cors_origins = "*"

# ──────────────────────────────────────────────
# EXPERT ROUTER (Functionary)
# ──────────────────────────────────────────────
# Uses a small Functionary model to classify incoming requests
# and route them to the appropriate CCA expert entry.

[router]
enabled = true
url = "http://localhost:8001"
timeout_ms = 10000
fallback_entry = "coder"
temperature = 0.1

# In-loop tool selection (Functionary-based smart tool escalation)
[tool_router]
enabled = true
url = "http://localhost:8001"
timeout_ms = 10000
temperature = 0.1

# ──────────────────────────────────────────────
# WORKSPACE — Repository Management (Single Source of Truth)
# ──────────────────────────────────────────────
# Defines ALL repos cloned into /workspace.  Both workspace-sync (git
# clone/pull) and the CCA indexer (Qdrant/Memgraph) derive their project
# lists from this section.  To add/remove a repo, edit here and restart
# workspace-sync.

[workspace]
sync_interval = 60                      # seconds between git pulls

# Credentials — authentication for git servers.
# ${VAR} references are resolved from environment variables at runtime
# so passwords/tokens never live in this file.
[[workspace.credentials]]
id = "gitlab-local"
url = "http://YOUR_GITLAB_HOST:8929"
user = "root"
token = "${GITLAB_PASS}"                # Set GITLAB_PASS in .env

# To add GitHub repos:
# [[workspace.credentials]]
# id = "github"
# url = "https://github.com"
# user = "your-username"
# token = "${GITHUB_TOKEN}"            # Set GITHUB_TOKEN in .env

# Repositories — each entry is one repo managed in /workspace.
# type = "source"    → periodic git pull (CCA reads only)
# type = "migration" → clone once (CCA manages commits/push)
[[workspace.repos]]
name = "your-project"
repo = "root/your-project"
credential = "gitlab-local"
type = "source"
branch = "main"

[[workspace.repos]]
name = "your-project-migration"
repo = "root/your-project-migration"
credential = "gitlab-local"
type = "migration"
branch = "main"

# ──────────────────────────────────────────────
# CODE INTELLIGENCE — Workspace Indexer
# ──────────────────────────────────────────────
# The workspace monitor continuously checks configured projects for data
# integrity.  If `projects` is empty, project names are derived from
# [[workspace.repos]] automatically.

[indexer]
paths = ["/workspace"]
# projects = []                         # Empty → derived from workspace.repos
sync_interval = 300                     # seconds between monitor cycles
collection = "codebase_files"
skip_dirs = [".git", "node_modules", "__pycache__", ".venv", "venv", "build", "dist"]
